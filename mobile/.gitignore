# ── Arabic LLM training data (too large for GitHub) ───────────────────────────
# The archive.zip is 169 MB (over GitHub's 100 MB limit) and the 720 PNG
# training images are ~220 MB. Download them from Kaggle separately.
arabic LLM FINAL/Data/archive.zip
arabic LLM FINAL/Data/archive/

# ── Arabic LLM runtime data ───────────────────────────────────────────────────
# ChromaDB vector store (rebuilt on first run)
arabic LLM FINAL/chroma_db/
arabic LLM FINAL/chroma.sqlite3
# UUID-named ChromaDB collection folders
arabic LLM FINAL/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]-*/
# Chat logs & uploads (runtime-generated)
arabic LLM FINAL/logs/
**/chat_logs.jsonl
**/uploads/

