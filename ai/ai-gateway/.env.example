# ──────────────────────────────────────────────
# Findoor AI Gateway — environment variable template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────

# ── LLM Keys ─────────────────────────────────
# Primary LLM — get key at console.groq.com
GROQ_API_KEY=gsk_replace_with_real_groq_key

# Fallback LLM — get key at aistudio.google.com
GEMINI_API_KEY=replace_with_real_gemini_key

# ── API Security ──────────────────────────────
# Shared secret between Node.js backend and this gateway
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=replace_with_32_char_random_hex

# ── MongoDB (for RAG data ingestion) ─────────
MONGODB_URI=mongodb://localhost:27017/findoor

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Session Store (optional — in-process if unset) ──
# Set to enable Redis-backed sessions (required for multi-instance scaling)
# REDIS_URL=redis://localhost:6379/0

# ── ChromaDB (optional — defaults to in-process) ──
# CHROMA_HOST=localhost
# CHROMA_PORT=8001
